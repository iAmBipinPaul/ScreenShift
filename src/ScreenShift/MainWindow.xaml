<Window x:Class="ScreenShift.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:local="clr-namespace:ScreenShift"
         Title="ScreenShift"
         MinWidth="340"
         SizeToContent="WidthAndHeight"
         WindowStyle="None"
         AllowsTransparency="True"
         Background="Transparent"
         ShowInTaskbar="False"
         Topmost="True"
         ResizeMode="NoResize"
         Deactivated="Window_Deactivated">
    
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        
        <!-- Monitor List Item Style -->
        <Style x:Key="MonitorItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Monitor Button -->
        <Style x:Key="MonitorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfacePressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Utility Icon Button -->
        <Style x:Key="UtilityButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfacePressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Status Badge Style -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </Window.Resources>
    
    <!-- Main container with Windows 11 style -->
    <Border Background="{DynamicResource AppBackgroundBrush}" 
            CornerRadius="16" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <StackPanel>
                <!-- Header -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="16,16,0,0" 
                        Padding="16,14,16,12"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="32"
                                    Height="32"
                                    CornerRadius="10"
                                    Background="{DynamicResource AccentBrush}"
                                    Margin="0,0,12,0">
                                <TextBlock Text="&#x25A3;"
                                           FontSize="16"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ScreenShift"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Manage displays"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="{DynamicResource StatusPillBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,5"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                            <TextBlock x:Name="StatusText"
                                       Text="Ready"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       MaxWidth="140"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </Grid>
                </Border>
                 
                <!-- Visual Monitor Layout -->
                <Border Background="{DynamicResource AppBackgroundBrush}" Padding="14,12,14,8">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10,12,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="DISPLAY LAYOUT"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="2,0,0,10"/>
                            <Border Grid.Row="1" 
                                    Background="{DynamicResource AppBackgroundBrush}"
                                    CornerRadius="8"
                                    Padding="4">
                                <Canvas x:Name="MonitorCanvas" Height="100" ClipToBounds="True" HorizontalAlignment="Stretch">
                                    <!-- Monitor items will be added programmatically -->
                                </Canvas>
                            </Border>
                        </Grid>
                    </Border>
                </Border>
                 
                <!-- Monitor List -->
                <ItemsControl x:Name="MonitorList" Margin="14,4,14,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MonitorButtonStyle}"
                                    Margin="0,4"
                                    Click="MonitorButton_Click"
                                    Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ItemBorder" 
                                                Background="{DynamicResource SurfaceBrush}" 
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14,12"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Display Number Badge -->
                                                <Border x:Name="NumberBadge"
                                                        Grid.Column="0" 
                                                        Width="32" Height="32" 
                                                        CornerRadius="8"
                                                        Background="{DynamicResource MonitorIconBackgroundBrush}"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding DisplayNumber}" 
                                                               FontWeight="SemiBold" 
                                                               FontSize="14"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                
                                                <!-- Monitor Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock x:Name="MonitorNameText"
                                                               Text="{Binding DeviceName}" 
                                                               FontSize="13" 
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock x:Name="MonitorMetaText" 
                                                               FontSize="11" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,3,0,0">
                                                        <Run Text="{Binding Width, Mode=OneWay}"/>
                                                        <Run Text="×"/>
                                                        <Run Text="{Binding Height, Mode=OneWay}"/>
                                                        <Run Text=" • "/>
                                                        <Run Text="{Binding Orientation, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                
                                                <!-- Status Badges -->
                                                <StackPanel Grid.Column="2" 
                                                            VerticalAlignment="Center"
                                                            Margin="12,0,0,0">
                                                    <Border x:Name="PrimaryBadge"
                                                            Style="{StaticResource StatusBadgeStyle}"
                                                            Background="{DynamicResource AccentBrush}"
                                                            Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="PRIMARY" 
                                                                   FontSize="9" 
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <Border x:Name="DisabledBadge"
                                                            Style="{StaticResource StatusBadgeStyle}"
                                                            Background="{DynamicResource MonitorIconBackgroundBrush}"
                                                            Visibility="{Binding IsEnabled, Converter={StaticResource InverseBoolToVisibility}}">
                                                        <TextBlock Text="DISABLED" 
                                                                   FontSize="9" 
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsPrimary}" Value="True">
                                                <Setter TargetName="NumberBadge" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="NumberBadge" Property="Width" Value="32"/>
                                                <Setter TargetName="NumberBadge" Property="Height" Value="32"/>
                                                <Setter TargetName="NumberBadge" Property="CornerRadius" Value="8"/>
                                                <Setter TargetName="MonitorNameText" Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.6"/>
                                                <Setter TargetName="MonitorNameText" Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Footer -->
                <Border Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="0,0,16,16" 
                        Padding="14,12,14,14"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1,1,0,0">
                    <StackPanel>
                        <!-- Startup Option -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Launch at startup"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1"
                                      x:Name="StartupCheckBox"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      Checked="StartupCheckBox_Changed"
                                      Unchecked="StartupCheckBox_Changed"/>
                        </Grid>
                        
                        <!-- Primary Display Action -->
                        <Button x:Name="DisplayToggleButton"
                                Content="Enable primary only"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Margin="0,0,0,10"
                                HorizontalContentAlignment="Center"
                                Click="DisplayToggleButton_Click"/>

                        <!-- Divider -->
                        <Border Height="1" 
                                Background="{DynamicResource BorderBrush}" 
                                Margin="0,0,0,10"/>
                        
                        <!-- Utility Buttons Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    ToolTip="Refresh displays"
                                    Style="{StaticResource UtilityButtonStyle}"
                                    Margin="0,0,4,0"
                                    Click="RefreshButton_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="↻" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                             <Button Grid.Column="1"
                                     x:Name="ThemeButton"
                                     ToolTip="Toggle theme"
                                     Style="{StaticResource UtilityButtonStyle}"
                                     Margin="4,0,4,0"
                                     Click="ThemeButton_Click">
                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                     <TextBlock Text="☀" FontSize="14" Margin="0,0,6,0"/>
                                     <TextBlock Text="Theme" VerticalAlignment="Center"/>
                                 </StackPanel>
                             </Button>

                            <Button Grid.Column="2"
                                    ToolTip="Exit application"
                                    Style="{StaticResource UtilityButtonStyle}"
                                    Margin="4,0,0,0"
                                    Click="ExitButton_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="✕" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Exit" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Theme Popup -->
            <Popup x:Name="ThemePopup" 
                   StaysOpen="False" 
                   Placement="Bottom" 
                   PlacementTarget="{Binding ElementName=ThemeButton}">
                <Border Background="{DynamicResource SurfaceBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="6">
                    <StackPanel>
                        <Button Content="System Default" 
                                Tag="System" 
                                Click="ThemeOption_Click" 
                                Style="{StaticResource UtilityButtonStyle}" 
                                HorizontalContentAlignment="Left"/>
                        <Button Content="Light" 
                                Tag="Light" 
                                Click="ThemeOption_Click" 
                                Style="{StaticResource UtilityButtonStyle}" 
                                HorizontalContentAlignment="Left"/>
                        <Button Content="Dark" 
                                Tag="Dark" 
                                Click="ThemeOption_Click" 
                                Style="{StaticResource UtilityButtonStyle}" 
                                HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </Border>
            </Popup>
            
            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" 
                    Background="{DynamicResource AppBackgroundBrush}" 
                    CornerRadius="16" 
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-20,0,0">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="160" 
                                 Height="3" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Loading displays..."
                               Margin="0,14,0,0" 
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
