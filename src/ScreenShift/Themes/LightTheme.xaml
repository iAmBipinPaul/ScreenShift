<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- AditiKraft Brand Colors - Light Theme -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F6F4"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#EEF3EF"/>
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="#E4ECE8"/>
     
    <!-- Border -->
    <SolidColorBrush x:Key="BorderBrush" Color="#C7D8D1"/>
    <Color x:Key="SurfaceHoverColor">#EEF3EF</Color>
     
    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E2B29"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#536660"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#8EA19B"/>
     
    <!-- Accent - Aditi Kraft Heritage Teal -->
    <SolidColorBrush x:Key="AccentBrush" Color="#0B6B61"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#0B6B61"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#08564F"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#063F3B"/>
    <SolidColorBrush x:Key="GoldAccentBrush" Color="#9A6412"/>
    <SolidColorBrush x:Key="StatusPillBackgroundBrush" Color="#EEF3EF"/>
    <Color x:Key="AccentColor">#0B6B61</Color>
    <Color x:Key="BorderColor">#C7D8D1</Color>
     
    <!-- Monitor Icons -->
    <SolidColorBrush x:Key="MonitorIconBackgroundBrush" Color="#EEF3EF"/>
</ResourceDictionary>
